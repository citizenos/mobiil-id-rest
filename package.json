{
  "name": "mobiil-id-rest",
  "version": "2.0.0",
  "description": "Simple Estonian Mobiil-ID REST client",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "NODE_ENV=test FORCE_DB_SYNC=1 NODE_TLS_REJECT_UNAUTHORIZED=0 mocha --require ts-node/register --expose-gc --async-only --check-leaks --trace-deprecation --reporter spec --exit --timeout 120000 --recursive --ui tdd test/"
  },
  "keywords": [
    "mobiil-id"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/citizenos/mobiil-id-rest.git"
  },
  "author": "Ilmar Türk",
  "license": "ISC",
  "homepage": "https://github.com/citizenos/mobiil-id-rest#readme",
  "bugs": {
    "url": "https://github.com/citizenos/mobiil-id-rest/issues"
  },
  "dependencies": {
    "asn1js": "^3.0.10",
    "axios": "^1.17.0",
    "elliptic": "^6.6.1",
    "log4js": "^6.9.1",
    "node-forge": "^1.4.0",
    "pkijs": "^3.4.0",
    "simple_rsautl": "1.0.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/elliptic": "^6.4.18",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.3",
    "@types/node-forge": "^1.3.14",
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
